{
  "schemaRevision": 1,
  "registries": [
    {
      "kind": "object_kind",
      "key": "plugin",
      "name": "Plugin",
      "description": "A versioned host plugin with localizable user-interface content."
    },
    {
      "kind": "fact_schema",
      "key": "plugin_min_app_version_semver_v1",
      "scope": "object_version",
      "jsonSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "string",
        "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
      }
    },
    {
      "kind": "fact_schema",
      "key": "plugin_supported_platforms_v1",
      "scope": "object_version",
      "jsonSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "array",
        "items": { "enum": ["desktop", "mobile"] },
        "minItems": 1,
        "uniqueItems": true
      }
    },
    {
      "kind": "external_registry",
      "key": "obsidian_community_plugins",
      "name": "Obsidian Community Plugins",
      "typedContract": {
        "type": "string",
        "pattern": "^[^/\\s]+/[^/\\s]+$"
      }
    }
  ]
}
