{
  "name": "@trans-hub/language-tags",
  "version": "0.0.1",
  "description": "Shared structural language-tag contract for Trans-Hub TypeScript clients",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/**/*", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@10.34.4",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "Apache-2.0"
}
