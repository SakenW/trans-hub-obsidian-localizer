{
  "name": "@trans-hub/client-protocol",
  "version": "0.1.0",
  "description": "Public, fail-closed wire protocol contracts for Trans-Hub clients",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "test-vectors"
  ],
  "dependencies": {
    "@trans-hub/language-tags": "workspace:^",
    "@trans-hub/uida": "workspace:^"
  },
  "scripts": {
    "build": "tsup",
    "benchmark": "pnpm build && node benchmarks/run.mjs --verify",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check --config-path biome.json ."
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@10.34.4",
  "license": "Apache-2.0"
}
